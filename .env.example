# MiCAR Compliance Agent Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (required for real mode, not needed for mock mode)
MAS_OPENAI_API_KEY=sk-your-key-here

# Model selection (default: gpt-4o)
MAS_OPENAI_MODEL=gpt-4o

# LLM parameters for reproducibility
MAS_TEMPERATURE=0.0
MAS_SEED=42

# Prompt version (default: v1)
MAS_PROMPT_VERSION=v1

# Mock mode: set to true to use pre-computed responses (no API key needed)
MAS_MOCK_MODE=false
